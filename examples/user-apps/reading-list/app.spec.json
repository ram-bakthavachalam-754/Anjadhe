          "empty": "No books yet — add your first one above.",
          "sort": { "by": "createdAt", "dir": "desc" },
          "editFields": [
            { "name": "title", "label": "Title", "input": "text", "required": true },
            { "name": "author", "label": "Author", "input": "text" },
            { "name": "status", "label": "Status", "input": "select", "options": ["reading", "finished", "want to read"] }
          ] }
